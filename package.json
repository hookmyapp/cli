{
  "name": "@gethookmyapp/cli",
  "version": "0.9.6",
  "description": "HookMyApp CLI, No BS. Just go live.",
  "type": "module",
  "bin": {
    "hookmyapp": "bin/hookmyapp.js"
  },
  "scripts": {
    "build": "node build.mjs",
    "dev": "tsx src/index.ts",
    "test": "vitest run --reporter=verbose",
    "test:unit": "vitest run --reporter=verbose",
    "test:integration": "vitest run --config vitest.integration.config.ts --reporter=verbose",
    "test:integration:nightly": "vitest run --config vitest.nightly.config.ts --reporter=verbose",
    "sync:errors-manifest": "node scripts/sync-errors-manifest.mjs",
    "sync:errors-manifest:check": "node scripts/sync-errors-manifest.mjs --check"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@sentry/node": "^10.49.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.0",
    "nanoid": "^5.1.7",
    "open": "^11.0.0",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1",
    "posthog-node": "^5.29.6",
    "qrcode-terminal": "0.12.0",
    "tar": "^7.5.13"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "esbuild": "^0.25.0",
    "execa": "^9.6.1",
    "playwright": "^1.59.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hookmyapp/cli.git"
  },
  "homepage": "https://hookmyapp.com",
  "bugs": {
    "url": "https://github.com/hookmyapp/cli/issues"
  },
  "keywords": [
    "whatsapp",
    "whatsapp-business-api",
    "webhook",
    "cli",
    "hookmyapp"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
